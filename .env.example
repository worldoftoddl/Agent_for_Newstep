# LLM (상용 — 기본 라우트 anthropic:)
ANTHROPIC_API_KEY=

# LLM (로컬 — local: 라우트, vLLM/Ollama OpenAI 호환 엔드포인트)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1

# LangSmith 트레이싱 (선택)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=excelbrief

# auditPaper_MCP — 기준서 RAG (HTTP: HF Space + Bearer 토큰)
MCP_TRANSPORT=http
