# LLM 벤더 키 — 설정된 벤더의 모델만 UI 드롭다운에 노출된다 (ui/src/lib/models.ts)
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=          # 또는 GOOGLE_API_KEY

# LLM (로컬 — local: 라우트, Ollama/vLLM OpenAI 호환 엔드포인트)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1

# LangSmith 트레이싱 (선택)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=excelbrief

# auditPaper_MCP — 기준서 RAG (HTTP: HF Space + Bearer 토큰)
MCP_TRANSPORT=http
MCP_HTTP_URL=https://toddl-auditpaper-mcp.hf.space/mcp
MCP_AUTH_TOKEN=

# stdio 로컬 옵션용 (MCP_TRANSPORT=stdio일 때만 사용)
# AUDITPAPER_MCP_DIR=/path/to/auditPaper_MCP
# QDRANT_URL=
# QDRANT_API_KEY=

# 조서 폴더
WORKPAPERS_DIR=data/workpapers
